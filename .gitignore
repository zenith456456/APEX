# ─── .gitignore ────────────────────────────────────────────────────────────

# Environment & secrets — NEVER commit real tokens
.env
.env.local
.env.*.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local data / state (signal memory should not be committed)
data/
*.db
*.sqlite3

# Northflank / Docker
.northflank/
*.pyc

# Jupyter
.ipynb_checkpoints/

# Test cache
.pytest_cache/
.coverage
htmlcov/
