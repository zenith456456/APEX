# ── Secrets — NEVER commit these ─────────────────────────────────
.env
*.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-wheel-metadata/
*.egg-info/
.eggs/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Runtime data (generated at runtime, not source) ───────────────
data/*.json
data/*.db
data/*.log
data/*.sqlite
*.log
logs/

# ── IDEs ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
