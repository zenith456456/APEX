{
  "apiVersion": "v1",
  "spec": {
    "kind": "DeploymentService",
    "spec": {
      "name": "apex-quant-bot",
      "billing": {
        "deploymentPlan": "nf-compute-10"
      },
      "deployment": {
        "instances": 1,
        "docker": {
          "configType": "default"
        },
        "internal": {
          "buildFilePath": "Dockerfile"
        }
      },
      "ports": [
        {
          "name":         "health",
          "internalPort": 8080,
          "public":       true,
          "protocol":     "HTTP"
        }
      ],
      "healthChecks": [
        {
          "protocol":             "HTTP",
          "path":                 "/health",
          "port":                 8080,
          "initialDelaySeconds":  25,
          "periodSeconds":        30,
          "timeoutSeconds":       10,
          "failureThreshold":     3,
          "successThreshold":     1
        }
      ]
    }
  }
}
