{
  "apiVersion": "v1",
  "spec": {
    "kind": "DeploymentService",
    "spec": {
      "name": "apex-quant-bot",
      "billing": {
        "deploymentPlan": "nf-compute-10"
      },
      "deployment": {
        "instances": 1,
        "docker": {
          "configType": "default"
        },
        "buildpack": {
          "configType": "default"
        },
        "internal": {
          "buildCommand": "pip install -r requirements.txt",
          "startCommand":  "python main.py",
          "buildFilePath": "Dockerfile"
        }
      },
      "ports": [
        {
          "name":     "health",
          "internalPort": 8080,
          "public":   true,
          "protocol": "HTTP"
        }
      ],
      "healthChecks": [
        {
          "protocol":    "HTTP",
          "path":        "/health",
          "port":        8080,
          "initialDelaySeconds": 20,
          "periodSeconds":       30,
          "timeoutSeconds":      10,
          "failureThreshold":    3
        }
      ]
    }
  }
}
