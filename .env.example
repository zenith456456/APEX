# ── Copy this file to .env and fill in your values ────────────────────────
# NEVER commit the .env file to GitHub

# ── Binance (read-only key is sufficient) ─────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Telegram ───────────────────────────────────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token below
TELEGRAM_TOKEN=123456789:ABCDefGhIJKlmNOPqrsTUVwxyz

# Step 2: Add bot to your channel/group, then get chat ID from @userinfobot
# Use negative ID for groups/channels e.g. -1001234567890
TELEGRAM_CHAT_IDS=-1001234567890

# ── Discord ────────────────────────────────────────────────────────────────
# Option A — Webhook (RECOMMENDED — easiest)
# Discord Server → Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Option B — Bot Token (leave blank if using webhook above)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
