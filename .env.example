# ─── .env.example ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file (already in .gitignore).
# In Northflank, set these as Environment Variables in the dashboard instead.

# ── Telegram ────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxYZ
# Channel/group ID (use @userinfobot or getUpdates API to find it)
TELEGRAM_CHANNEL_ID=-1001234567890

# ── Discord (optional — leave blank to disable) ─────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── Binance (optional — public market data does not require keys) ──────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Scanner Settings ─────────────────────────────────────────────────────────
SCAN_INTERVAL_SEC=30
LISTING_CHECK_MIN=60
MAX_PAIRS=200
MIN_VOLUME_USDT=1000000

# ── Signal Thresholds ────────────────────────────────────────────────────────
MTCS_MIN_SCORE=55

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
BOT_NAME=APEX Signal Bot
