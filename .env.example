# ════════════════════════════════════════════════════════════
#   APEX-QUANT  ·  Environment Variables
#
#   LOCAL DEV:  copy this file to .env  and fill in values
#               pip install -r requirements.txt && python main.py
#
#   NORTHFLANK: do NOT upload this file.
#               Instead: Service → Environment → Add Variable
#               for each variable below. Do NOT include quotes.
# ════════════════════════════════════════════════════════════


# ── REQUIRED ─────────────────────────────────────────────────────

# Telegram bot token from @BotFather
# Step 1: Message @BotFather → /newbot → follow prompts → copy token
# Step 2: Add your new bot to your channel/group as admin
# Step 3: Paste token below (no quotes)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram channel/group chat ID
# How to get it:
#   Add @userinfobot to your group → it will reply with the ID
#   For channels: forward any channel post to @userinfobot
# Format: -100XXXXXXXXXX  (negative number, no quotes)
TELEGRAM_CHAT_ID=-1001234567890

# Discord incoming webhook URL
# How to get it:
#   Discord → right-click channel → Edit Channel
#   → Integrations → Webhooks → New Webhook → Copy Webhook URL
# Format: https://discord.com/api/webhooks/XXXXXXXXXX/XXXX...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXXXXXX


# ── OPTIONAL (safe defaults shown) ───────────────────────────────

# Timeframes to scan (comma-separated)
SCAN_TIMEFRAMES=1m,3m,5m

# Minimum 24h USDT quote volume for a pair to be included
MIN_VOLUME_USDT=5000000

# Minimum Composite Signal Score to emit a signal (0-100)
MIN_CSS_SCORE=75

# Maximum number of USDT pairs tracked simultaneously
MAX_PAIRS=30

# Minimum minutes between signals for the same pair
SIGNAL_COOLDOWN_MINUTES=5

# VPI absolute minimum (volume pressure confirmation)
VPI_MIN_ABS=20

# FDI maximum (above this = choppy market, block entries)
FDI_MAX=1.60

# HTTP health-check port (Northflank uses this to verify service is alive)
PORT=8080

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# Use DEBUG temporarily to see every candle evaluation
LOG_LEVEL=INFO
