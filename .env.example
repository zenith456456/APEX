# ─── Binance ──────────────────────────────────────────────────────────────
# Read-only API key is sufficient (bot never places orders)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─── Telegram ─────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=123456789:ABCDefGhIJKlmNOPqrsTUVwxyz

# Comma-separated chat IDs (group or channel — use negative ID for groups)
# Get your chat ID by messaging @userinfobot
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# ─── Discord ──────────────────────────────────────────────────────────────
# Option A — Webhook (easiest, recommended)
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Option B — Bot token (if you use a Discord bot instead of webhook)
# Leave blank if using webhook above
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
