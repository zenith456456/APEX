# ─────────────────────────────────────────────────────────────────
#  IDS Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────
# Get token from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Add bot to your channel as Admin, then get ID:
# Forward any message from the channel to @userinfobot
# It looks like:  -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=

# ── Discord ───────────────────────────────────────────────────────
# discord.com/developers → New Application → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Right-click your channel → Copy Channel ID
# (Enable Developer Mode: User Settings → Advanced → Developer Mode)
DISCORD_CHANNEL_ID=

# ── Scanner Settings ──────────────────────────────────────────────
# Minimum 24h USDT volume to include a coin in the scan universe
MIN_VOLUME_USDT=5000000

# AI Score threshold to fire a signal (range: 0–100, recommended: 72–80)
AI_SCORE_THRESHOLD=72

# Minimum R:R ratio — signals below this are hard-rejected
MIN_RR=1.0

# How many historical candles to keep per symbol in memory
CANDLE_LIMIT=200

# How often (seconds) to refresh the coin universe from Binance
# This is how new listings are auto-detected (default: 10 minutes)
UNIVERSE_REFRESH_SECS=600

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
